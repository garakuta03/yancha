# 共通
YANCHA_LOG_LEVEL=info
YANCHA_ASSETS_DIR=assets

# LLM設定: gemini / openai / mock
YANCHA_LLM_PROVIDER=gemini
YANCHA_LLM_MODEL=gemini-1.5-flash

# OpenAIを使う場合
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Geminiを使う場合
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# 外部ツールの将来接続先
COMFYUI_BASE_URL=http://127.0.0.1:8188
FFMPEG_PATH=ffmpeg

# リサーチ定点観測
YOUTUBE_API_KEY=
YOUTUBE_BASE_URL=https://www.googleapis.com/youtube/v3
YANCHA_RESEARCH_DIR=research-data
RESEARCH_PORT=5177
# 発掘(プランB/C)は YANCHA_RESEARCH_DIR/keywords.yaml を使う（packages/research/keywords.example.yaml 参照）

# YouTubeアップロード（OAuth2。上のYOUTUBE_API_KEYとは別物）
# OAuth同意画面は必ず「本番公開」にすること。テストモードのrefresh tokenは7日で失効する可能性が高い。
# スコープは https://www.googleapis.com/auth/youtube.upload のみ。
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
