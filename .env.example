# 共通
YANCHA_LOG_LEVEL=info
YANCHA_ASSETS_DIR=assets

# LLM設定: gemini / openai / mock
YANCHA_LLM_PROVIDER=gemini
YANCHA_LLM_MODEL=gemini-1.5-flash

# OpenAIを使う場合
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Geminiを使う場合
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# 外部ツールの将来接続先
COMFYUI_BASE_URL=http://127.0.0.1:8188
FFMPEG_PATH=ffmpeg
