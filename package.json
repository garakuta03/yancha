{
  "name": "yancha",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline": "tsx --env-file-if-exists=.env src/cli.ts pipeline",
    "research": "tsx --env-file-if-exists=.env packages/research/src/cli.ts",
    "stage": "tsx --env-file-if-exists=.env src/cli.ts stage"
  },
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=11.0.0"
  },
  "dependencies": {
    "@yancha/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
